# new-api 运行配置（Operit Ubuntu chroot 部署）
# 复制自 new-api.env.example 后修改
# 所有环境变量都可被 new-api 读取，等号两侧不要有多余空格

# ---------- 监听 ----------
PORT=3000
HOST=0.0.0.0

# ---------- 数据库 ----------
# Operit chroot 部署强烈建议只用 SQLite，不要装 MySQL/Redis 污染系统
# 留空 = 使用默认 SQLite（/opt/new-api/data/one-api.db）
SQL_DSN=

# ---------- 缓存 ----------
# 内存缓存（无需 Redis），适合单机部署
MEMORY_CACHE_ENABLED=true

# ---------- 安全 ----------
# 会话加密密钥，务必改成 32+ 位随机字符串！
# 可用命令生成：openssl rand -hex 32
SESSION_SECRET=请改成你自己的32位以上随机字符串

# ---------- 日志 ----------
LOG_DIR=/opt/new-api/data/logs
ERROR_LOG_ENABLED=true

# ---------- 其他 ----------
TZ=Asia/Shanghai

# 如需禁用注册，取消下行注释
# REGISTER_ENABLED=false

# 如需禁用游客访问，取消下行注释
# GUEST_ENABLED=false
